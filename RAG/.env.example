# ============================================================
# Configuración de entorno: SaludPlus Perú - Triage IA
# Copia este archivo a .env y completa tus credenciales.
# NUNCA subas .env a git (ya está en .gitignore).
# ============================================================

# Proveedor de LLM: google | openai
LLM_PROVIDER=google

# --- Google Gemini ---
GOOGLE_API_KEY=tu_api_key_de_google_aistudio_aqui
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (opcional) ---
# OPENAI_API_KEY=tu_api_key_de_openai_aqui
# OPENAI_MODEL=gpt-4o-mini

# Proveedor de embeddings: local | google
# - local: usa sentence-transformers (sin cuota de API)
# - google: usa GoogleGenerativeAIEmbeddings (consume cuota de Gemini)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Rutas del proyecto
CHROMA_PERSIST_DIR=./chroma_db
DATA_JSON_PATH=./data/saludplus_data.json
